# Safety rules — command allow/deny list for Codex CLI
# Starlark syntax. prefix_rule(allow/deny, pattern)

# Allow common development tools
prefix_rule(allow, "git ")
prefix_rule(allow, "npm ")
prefix_rule(allow, "npx ")
prefix_rule(allow, "node ")
prefix_rule(allow, "pnpm ")
prefix_rule(allow, "yarn ")
prefix_rule(allow, "bun ")
prefix_rule(allow, "python ")
prefix_rule(allow, "pip ")
prefix_rule(allow, "cargo ")
prefix_rule(allow, "go ")
prefix_rule(allow, "ls ")
prefix_rule(allow, "cat ")
prefix_rule(allow, "echo ")
prefix_rule(allow, "pwd")
prefix_rule(allow, "mkdir ")
prefix_rule(allow, "cp ")
prefix_rule(allow, "mv ")
prefix_rule(allow, "Get-ChildItem")
prefix_rule(allow, "Get-Content")
prefix_rule(allow, "Select-String")
prefix_rule(allow, "Set-Location")
prefix_rule(allow, "Resolve-Path")

# Deny destructive commands
prefix_rule(deny, "rm -rf ")
prefix_rule(deny, "rm -r /")
prefix_rule(deny, "rm -f /")
prefix_rule(deny, "sudo rm")
prefix_rule(deny, "git push --force")
prefix_rule(deny, "git reset --hard")
prefix_rule(deny, "git clean -fd")
prefix_rule(deny, "DROP TABLE")
prefix_rule(deny, "DROP DATABASE")
prefix_rule(deny, "truncate ")
prefix_rule(deny, "format ")
prefix_rule(deny, "mkfs")
prefix_rule(deny, "dd if=")
prefix_rule(deny, "chmod 777")
prefix_rule(deny, "curl | bash")
prefix_rule(deny, "wget -O- |")
prefix_rule(deny, "del ")
prefix_rule(deny, "rd /s")
prefix_rule(deny, "rmdir /s")
prefix_rule(deny, "Remove-Item ")
