{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/scripts/session-start.cjs\"",
            "commandWindows": "powershell -NoProfile -Command \"node (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/scripts/session-start.cjs')\"",
            "timeout": 10,
            "statusMessage": "Loading project workflow"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/scripts/pre-tool-safety.cjs\"",
            "commandWindows": "powershell -NoProfile -Command \"node (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/scripts/pre-tool-safety.cjs')\"",
            "timeout": 5,
            "statusMessage": "Checking destructive command policy"
          }
        ]
      }
    ]
  }
}
