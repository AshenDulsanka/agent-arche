{
  "name": "agent-arche",
  "version": "1.2.5",
  "description": "Multi-platform AI agent orchestration for GitHub Copilot, Claude Code, and Codex",
  "keywords": [
    "github-copilot",
    "claude-code",
    "codex",
    "ai-agents",
    "orchestration",
    "agents",
    "skills"
  ],
  "homepage": "https://github.com/AshenDulsanka/agent-arche#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshenDulsanka/agent-arche.git"
  },
  "bugs": {
    "url": "https://github.com/AshenDulsanka/agent-arche/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-arche": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx bin/cli.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:dist": "tsc -p tsconfig.build.json",
    "prepack": "npm run clean && npm run build:dist"
  },
  "files": [
    "copilot/",
    "claude/",
    "codex/",
    "skills/",
    "memory/",
    "dist/",
    "templates/"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.18",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
